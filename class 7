// OOP

class Person {
  String name;
  int age;

  // Constructor
  Person(this.name, this.age);

  // Method
  void greet() {
    print("Hello, my name is $name and I am $age years old.");
  }
}

void main() {
  var person = Person('Saad', 20);
  person.greet(); // Output: Hello, my name is Saad and I am 20 years old.
}
