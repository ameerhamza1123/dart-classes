void main() {
  show();

  print(sum("Flutter", " Development"));
  print(para("Programming"));
  print(paraa());
  print(add());

  dynamic items = [25, 40, 60, 85, "Flutter", "Coding"];

  for (var value in items) {
    print(value);
  }
  print(items);

  List<int> numbers = [5, 10, 15, 20];
  List<String> languages = ["Java", "Python", "C++", "Dart"];
  List<bool> status = [false, true];

  for (var num in numbers) {
    print("Number is $num");
  }

