void show() {
  print("This is a function");
}

String sum(String a, String b) {
  print(a + b);
  return a + b;
}

String para([a]) {
  return "This is $a function";
}

String paraa({a = "Flutter", b = " Programming"}) {
  print(a + b);
  return a + b;
}

